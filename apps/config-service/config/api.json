{
  "name": "API Gateway",
  "host": "${API_HOST:0.0.0.0}",
  "port": "${API_PORT:8080}",
  "cors": {
    "origin": "${CORS_ALLOWED_ORIGIN:*}",
    "credentials": true
  },
  "auth": {
    "issuer": "${webapp.oidc.authority}",
    "audience": "api-gateway"
  },
  "rateLimit": {
    "windowMs": 60000,
    "max": 100
  },
  "logging": {
    "level": "${LOG_LEVEL:info}",
    "format": "json"
  }
}
